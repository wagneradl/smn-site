{
  "name": "smn-site",
  "version": "1.0.0",
  "description": "Site institucional SMN Tecnologia - Template Tailwind Studio Pro integrado",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "audit:json": "npm audit --audit-level=moderate --json > reports/audit.postfix.json",
    "build:prod": "next build",
    "build:turbopack": "next build --turbopack",
    "diag:env": "node scripts/diag/env-probe.mjs",
    "diag:audit": "node scripts/diag/deps-audit.mjs",
    "diag:mdx": "node scripts/diag/next-mdx-shiki-probe.mjs",
    "diag:tw": "node scripts/diag/tailwind-v4-sanity.mjs",
    "diag:nav": "node scripts/diag/nav-grid-scan.mjs",
    "diag:logos": "node scripts/diag/logos-layout-scan.mjs",
    "diag:quality": "node scripts/diag/eslint-prettier-typecheck.mjs",
    "diag:build": "node scripts/diag/build-probe.mjs",
    "diag:seo": "node scripts/diag/seo-scan.mjs",
    "diag:http": "node scripts/diag/http-endpoints.mjs",
    "diag:all": "npm run build && npm run format:check || true && npm run diag:mdx && npm run diag:logos && npm run diag:nav",
    "perf:lcp": "node scripts/perf/lcp-detect.mjs",
    "qa:smoke": "node scripts/qa/smoke-ux.mjs",
    "qa:seo": "npm run diag:seo && npm run diag:http && npm run perf:lcp",
    "qa:all": "npm run build && npm run qa:smoke",
    "analyze": "ANALYZE=true next build",
    "perf:budget": "npm run build && npm run diag:build && node scripts/perf/assert-budgets.mjs",
    "perf:lighthouse": "node scripts/perf/lighthouse.mjs",
    "fix:image-sizes": "node scripts/fix/image-sizes-codemod.mjs",
    "diag:image": "node scripts/diag/next-image-audit.mjs",
    "diag:rsc": "node scripts/diag/rsc-boundaries.mjs"
  },
  "browserslist": "defaults, not ie <= 11",
  "engines": {
    "node": ">=24.1.0"
  },
  "dependencies": {
    "@mdx-js/loader": "^3.1.0",
    "@mdx-js/react": "^3.1.0",
    "@next/mdx": "^15",
    "@shikijs/rehype": "3.11.0",
    "@tailwindcss/postcss": "^4.1.11",
    "@types/mdx": "^2.0.13",
    "acorn": "^8.15.0",
    "acorn-jsx": "^5.3.2",
    "clsx": "^2.1.1",
    "escape-string-regexp": "^5.0.0",
    "framer-motion": "^12.23.11",
    "next": "^15",
    "puppeteer": "^24.17.0",
    "react": "^19",
    "react-dom": "^19",
    "recma-import-images": "0.0.3",
    "rehype-unwrap-images": "^1.0.0",
    "remark-gfm": "^4.0.1",
    "remark-rehype-wrap": "0.0.5",
    "shiki": "3.11.0",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "unified-conditional": "0.0.2",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@lhci/cli": "^0.15.1",
    "@next/bundle-analyzer": "^15.5.2",
    "@types/node": "^24.1.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.32.0",
    "eslint-config-next": "^15",
    "fast-glob": "^3.3.3",
    "lighthouse": "^12.8.2",
    "prettier": "^3.6.2",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "serve": "^14.2.4",
    "sharp": "0.34.3"
  }
}
