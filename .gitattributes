# Configuração de atributos Git para controle de texto vs binário e EOL

# Arquivos de texto padrão (auto-detect, EOL LF)
* text=auto eol=lf

# Arquivos de imagem (binários)
*.{png,jpg,jpeg,gif,webp,svg} binary

# Fontes (binários)
*.{ttf,otf,woff,woff2,eot} binary

# Arquivos de mídia (binários)
*.{mp4,mp3,wav,avi,mov} binary

# Arquivos de documento (binários)
*.{pdf,doc,docx,xls,xlsx,ppt,pptx} binary

# Arquivos de arquivo (binários)
*.{zip,rar,7z,tar,gz,bz2} binary

# Scripts específicos (forçar LF)
*.sh text eol=lf
*.mjs text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.json text eol=lf
*.md text eol=lf
*.mdx text eol=lf
*.css text eol=lf
*.html text eol=lf
*.xml text eol=lf
*.yml text eol=lf
*.yaml text eol=lf

# Configurações específicas do projeto
*.config.{js,mjs,ts} text eol=lf
next.config.mjs text eol=lf
tailwind.config.js text eol=lf
postcss.config.js text eol=lf
prettier.config.js text eol=lf
